# Top-most EditorConfig file
root = true

# Global defaults
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python / Shell
[*.{py,sh,bash}]
indent_size = 4

# Makefile (requires tab)
[Makefile]
indent_style = tab

# Markdown
[*.md]
trim_trailing_whitespace = false
